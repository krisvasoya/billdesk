// backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id           String      @id @default(uuid())
  shopName     String      @map("shop_name")
  ownerName    String      @map("owner_name")
  email        String      @unique
  mobile       String
  gstNumber    String?     @map("gst")
  address      String?
  businessType String      @map("business_type")
  logoUrl      String?     @map("logo")
  currency     String      @default("INR")
  language     String      @default("en")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  createdBy    String?     @map("created_by")
  updatedBy    String?     @map("updated_by")

  users        User[]
  customers    Customer[]
  buyers       Buyer[]
  invoices     Invoice[]
  payments     Payment[]
  reports      Report[]
  settings     Settings?
  products     Product[]

  @@index([createdAt])
}

model User {
  id           String    @id @default(uuid())
  shopId       String
  name         String
  email        String    @unique
  mobile       String
  passwordHash String
  googleId     String?
  role         String    @default("owner") // owner, manager, employee, viewer
  avatar       String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    String?
  updatedBy    String?

  shop         Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([createdAt])
}

model Customer {
  id             String    @id @default(uuid())
  shopId         String    @map("shop_id")
  customerName   String    @map("customer_name")
  mobile         String?
  email          String?
  address        String?
  gstNumber      String?   @map("gst_number")
  openingBalance Float     @default(0.0) @map("opening_balance")
  creditLimit    Float     @default(0.0) @map("credit_limit")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")

  shop           Shop      @relation(fields: [shopId], references: [id])
  invoices       Invoice[]
  payments       Payment[]

  @@index([shopId])
  @@index([customerName])
  @@index([mobile])
  @@index([createdAt])
}

model Buyer {
  id             String    @id @default(uuid())
  shopId         String    @map("shop_id")
  buyerName      String    @map("buyer_name")
  mobile         String?
  email          String?
  address        String?
  gstNumber      String?   @map("gst_number")
  openingBalance Float     @default(0.0) @map("opening_balance")
  creditLimit    Float     @default(0.0) @map("credit_limit")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")

  shop           Shop      @relation(fields: [shopId], references: [id])
  invoices       Invoice[]

  @@index([shopId])
  @@index([buyerName])
  @@index([mobile])
  @@index([createdAt])
}

model Invoice {
  id              String        @id @default(uuid())
  shopId          String        @map("shop_id")
  invoiceNumber   String        @map("invoice_number")
  customerId      String?       @map("customer_id")
  buyerId         String?       @map("buyer_id")
  invoiceDate     DateTime      @map("invoice_date")
  dueDate         DateTime?     @map("due_date")
  subtotal        Float
  discount        Float         @default(0.0)
  gst             Float         @default(0.0)
  transportCharge Float         @default(0.0) @map("transport")
  packingCharge   Float         @default(0.0) @map("packing")
  otherCharge     Float         @default(0.0) @map("other_charges")
  grandTotal      Float         @map("grand_total")
  paidAmount      Float         @default(0.0) @map("paid_amount")
  pendingAmount   Float         @map("pending_amount")
  paymentStatus   String        @default("pending") @map("status") // paid, pending, partial, overdue
  notes           String?
  terms           String?
  pdfUrl          String?       @map("pdf_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  createdBy       String?       @map("created_by")
  updatedBy       String?       @map("updated_by")

  shop            Shop          @relation(fields: [shopId], references: [id])
  customer        Customer?     @relation(fields: [customerId], references: [id])
  buyer           Buyer?        @relation(fields: [buyerId], references: [id])
  items           InvoiceItem[]
  payments        Payment[]

  @@index([shopId])
  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([createdAt])
}

model InvoiceItem {
  id                  String    @id @default(uuid())
  invoiceId           String    @map("invoice_id")
  productId           String?   @map("product_id")
  productName         String    @map("product_name")
  description         String?
  alternativeQuantity Float?    @map("alt_quantity")
  quantity            Float
  unit                String
  rate                Float
  discount            Float     @default(0.0)
  gst                 Float     @default(0.0)
  total               Float
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  createdBy           String?   @map("created_by")
  updatedBy           String?   @map("updated_by")

  invoice             Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product             Product?  @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@index([createdAt])
}

model Payment {
  id              String    @id @default(uuid())
  shopId          String
  invoiceId       String?
  customerId      String?
  amount          Float
  paymentMethod   String // cash, upi, bank, cheque, card
  paymentDate     DateTime
  referenceNumber String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  shop            Shop      @relation(fields: [shopId], references: [id])
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([paymentDate])
  @@index([createdAt])
}

model Report {
  id          String    @id @default(uuid())
  shopId      String
  reportType  String // sales, outstanding, tax, activity
  parameters  String? // json config query
  fileUrl     String?
  generatedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?

  shop        Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([createdAt])
}

model Session {
  id        String    @id @default(uuid())
  shopId    String?
  userId    String
  token     String    @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([userId])
  @@index([token])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  shopId    String?
  userId    String
  token     String    @unique
  expiresAt DateTime
  isRevoked Boolean   @default(false)
  rotatedTo String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([userId])
  @@index([token])
  @@index([createdAt])
}

model ActivityLog {
  id        String    @id @default(uuid())
  shopId    String?
  userId    String?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([shopId])
  @@index([userId])
  @@index([createdAt])
}

model Settings {
  id                  String    @id @default(uuid())
  shopId              String    @unique
  invoiceNumberFormat String    @default("INV-{YYYY}-{NUMBER}")
  currency            String    @default("INR")
  language            String    @default("en")
  theme               String    @default("light")
  upiId               String?
  bankDetails         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?

  shop                Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([createdAt])
}

model Product {
  id          String        @id @default(uuid())
  shopId      String        @map("shop_id")
  productName String        @map("product_name")
  rate        Float         @default(0.0)
  gst         Float         @default(0.0)
  unit        String        @default("pcs")
  stock       Float?
  sku         String?
  barcode     String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")
  createdBy   String?       @map("created_by")
  updatedBy   String?       @map("updated_by")

  shop         Shop          @relation(fields: [shopId], references: [id])
  invoiceItems InvoiceItem[]

  @@index([shopId])
  @@index([productName])
  @@index([createdAt])
}
