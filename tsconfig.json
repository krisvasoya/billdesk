{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-native",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/services/*": [
        "./src/services/*"
      ],
      "@/providers/*": [
        "./src/providers/*"
      ],
      "@/contexts/*": [
        "./src/contexts/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ],
      "@/constants/*": [
        "./src/constants/*"
      ],
      "@/theme/*": [
        "./src/theme/*"
      ],
      "@/locales/*": [
        "./src/locales/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/storage/*": [
        "./src/storage/*"
      ],
      "@/animations/*": [
        "./src/animations/*"
      ]
    },
    "baseUrl": "."
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "node_modules.bak",
    "backend"
  ]
}
